{# Public site header: brand logo + contact CTA, floating over the dark homepage scene #}
{# Borderless gradient veil fading into the scene #}
{% set contact_href = path('app_contact') %}

<header class="absolute inset-x-0 top-0 z-20 bg-linear-to-b from-neutral-950/70 via-neutral-950/30 to-transparent pb-6 backdrop-blur-xs">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
        <a href="{{ path('app_home') }}" aria-label="Homepage" class="transition-opacity duration-200 hover:opacity-80">
            <img src="{{ asset('medias/logo/logo_long_white_gradian.svg') }}" alt="{{ 'layout.header.logo_alt'|trans }}" width="240" height="58" class="h-6 w-auto" loading="eager">
        </a>
        <a href="{{ contact_href }}" class="inline-flex items-center rounded-full border border-white/25 px-4 py-2 text-sm text-white transition-colors duration-200 hover:border-white/50 hover:bg-white/5 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white/70">
            {{ 'layout.header.contact'|trans }}
        </a>
    </div>
</header>
