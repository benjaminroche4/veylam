{# Public site header: brand + main navigation #}
<header class="border-b border-neutral-200">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
        <a href="{{ path('app_home') }}" class="font-serif text-xl font-semibold tracking-wide text-neutral-900 transition-colors duration-200 hover:text-neutral-500">
            {{ 'layout.brand'|trans }}
        </a>

        <nav aria-label="{{ 'layout.header.nav_label'|trans }}">
            <ul class="flex items-center gap-8 text-sm">
                <li>
                    <a href="{{ path('app_home') }}" class="text-neutral-600 transition-colors duration-200 hover:text-neutral-900">
                        {{ 'layout.header.home'|trans }}
                    </a>
                </li>
            </ul>
        </nav>
    </div>
</header>
