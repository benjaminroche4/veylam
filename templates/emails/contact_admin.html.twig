<div style="font-family: Helvetica, Arial, sans-serif; color: #171717; max-width: 560px;">
    <h1 style="font-size: 18px;">{{ 'contact.email.admin.title'|trans }}</h1>
    <p style="margin: 4px 0;"><strong>{{ 'contact.email.admin.from_name'|trans }}</strong> {{ contact_name }}</p>
    <p style="margin: 4px 0;"><strong>{{ 'contact.email.admin.from_email'|trans }}</strong> {{ contact_email }}</p>
    <p style="margin: 16px 0 4px;"><strong>{{ 'contact.email.admin.message'|trans }}</strong></p>
    <p style="white-space: pre-line; background: #f5f5f5; padding: 12px; border-radius: 8px;">{{ contact_message }}</p>
</div>
