{# Contact form fields, shared between the page and the Turbo Stream re-render #}
{% set input_classes = 'w-full rounded-lg border border-white/10 bg-white/5 px-4 py-3 text-white placeholder:text-neutral-500 transition-colors duration-200 focus:border-white/30 focus:outline-none' %}

{{ form_start(form) }}
    {% if form.vars.errors|length > 0 %}
        <div class="mb-6 rounded-lg border border-red-400/30 bg-red-400/10 px-4 py-3">
            {% for error in form.vars.errors %}
                <p class="text-sm text-red-300">{{ error.message }}</p>
            {% endfor %}
        </div>
    {% endif %}

    <div class="space-y-6">
        <div>
            {{ form_label(form.name, null, {label_attr: {class: 'mb-2 block text-sm text-neutral-300'}}) }}
            {{ form_widget(form.name, {attr: {class: input_classes}}) }}
            {% for error in form.name.vars.errors %}
                <p class="mt-1.5 text-sm text-red-400">{{ error.message }}</p>
            {% endfor %}
        </div>

        <div>
            {{ form_label(form.email, null, {label_attr: {class: 'mb-2 block text-sm text-neutral-300'}}) }}
            {{ form_widget(form.email, {attr: {class: input_classes}}) }}
            {% for error in form.email.vars.errors %}
                <p class="mt-1.5 text-sm text-red-400">{{ error.message }}</p>
            {% endfor %}
        </div>

        <div>
            {{ form_label(form.message, null, {label_attr: {class: 'mb-2 block text-sm text-neutral-300'}}) }}
            {{ form_widget(form.message, {attr: {class: input_classes, rows: 6}}) }}
            {% for error in form.message.vars.errors %}
                <p class="mt-1.5 text-sm text-red-400">{{ error.message }}</p>
            {% endfor %}
        </div>

        {# Honeypot: visually hidden, must stay empty #}
        <div class="hidden" aria-hidden="true">
            {{ form_label(form.website) }}
            {{ form_widget(form.website, {attr: {tabindex: '-1', autocomplete: 'off'}}) }}
        </div>

        <button type="submit" class="inline-flex items-center rounded-full bg-white px-5 py-2.5 text-sm font-medium text-neutral-950 transition-colors duration-200 hover:bg-neutral-200 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white">
            {{ 'contact.form.submit'|trans }}
        </button>
    </div>
{{ form_end(form) }}
