{% extends 'public/base.html.twig' %}

{% block title %}{{ 'contact.meta.title'|trans }}{% endblock %}
{% block description %}{{ 'contact.meta.description'|trans }}{% endblock %}
{% block url %}{{ url('app_contact') }}{% endblock %}

{% block schema_page %}
    {{ include('_partials/schema/organization.html.twig', {
        page_type: 'ContactPage',
        page_url: block('url'),
        page_title: block('title'),
        page_description: block('description'),
    }) }}
{% endblock %}

{% block body %}
    <section class="relative flex flex-1 items-center justify-center bg-neutral-950 px-6 py-28">
        <div class="w-full max-w-xl">
            <h1 class="text-3xl font-semibold text-white">{{ 'contact.hero.title'|trans }}</h1>
            <p class="mt-3 text-neutral-400">{{ 'contact.hero.subtitle'|trans }}</p>

            <div id="contact-form" class="mt-10">
                {% if success %}
                    <twig:Contact:Success />
                {% else %}
                    {{ include('public/contact/_form.html.twig') }}
                {% endif %}
            </div>
        </div>
    </section>
{% endblock %}
