{% extends 'public/base.html.twig' %}

{% block title %}{{ 'error.generic.title'|trans }}{% endblock %}
{% block description %}{{ 'error.generic.message'|trans }}{% endblock %}
{% block meta_robots %}<meta name="robots" content="noindex">{% endblock %}

{% block body %}
    <section class="relative flex flex-1 items-center justify-center bg-neutral-950 px-6 py-28">
        <div class="max-w-xl text-center">
            <h1 class="text-3xl font-light tracking-tight text-white sm:text-4xl">{{ 'error.generic.title'|trans }}</h1>
            <p class="mt-4 leading-7 text-neutral-400">{{ 'error.generic.message'|trans }}</p>
            <a href="{{ path('app_home') }}" class="mt-8 inline-flex items-center rounded-full border border-white/25 px-4 py-2 text-sm text-white transition-colors duration-200 hover:border-white/50 hover:bg-white/5">
                {{ 'error.back_home'|trans }}
            </a>
        </div>
    </section>
{% endblock %}
